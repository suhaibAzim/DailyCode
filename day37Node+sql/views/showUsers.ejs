<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Users</title>
    <style>table,th,tr,td{
        border: 1px solid black;
    }
    </style>
</head>
<body>
    <table>
        <tr>
            <th>ID</th>
            <th>USERNAME</th>
            <th>Email</th>
        </tr>
        <% for(user of result){ %>
        <tr>
            <td><%= user.ID%></td>
            <td><%= user.USERNAME%></td>
            <td><%= user.EMAIL%></td>
            <td>
                <form action="/users/<%=user.ID%>/edit">
                    <button>Edit</button>
                </form>
            </td>
        </tr>
        <% } %>
    </table>
</body>
</html>

